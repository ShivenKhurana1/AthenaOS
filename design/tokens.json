{
  "meta": {
    "name": "AthenaOS Glasskit",
    "version": "0.1.0"
  },
  "color": {
    "bg": {
      "base": "#f2f5fb",
      "wash": "#e7eef7",
      "accent": "#a8d8ff",
      "sun": "#ffd6a5"
    },
    "glass": {
      "base": "rgba(255, 255, 255, 0.6)",
      "strong": "rgba(255, 255, 255, 0.78)",
      "edge": "rgba(255, 255, 255, 0.9)"
    },
    "ink": {
      "primary": "#101218",
      "secondary": "#3b4251",
      "muted": "#6a7387"
    },
    "accent": {
      "blue": "#2f7ef7",
      "teal": "#2fb7c7",
      "lime": "#7ad38b"
    },
    "danger": "#e05252",
    "warning": "#e0a84d",
    "success": "#43b572"
  },
  "radius": {
    "xs": "6px",
    "sm": "10px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "blur": {
    "sm": "8px",
    "md": "16px",
    "lg": "28px"
  },
  "shadow": {
    "soft": "0 8px 24px rgba(16, 18, 24, 0.12)",
    "glass": "0 12px 36px rgba(16, 18, 24, 0.16)",
    "float": "0 20px 60px rgba(16, 18, 24, 0.2)"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "12px",
    "lg": "20px",
    "xl": "32px",
    "2xl": "48px"
  },
  "typography": {
    "fontFamily": {
      "display": "'Newsreader', serif",
      "ui": "'Space Grotesk', sans-serif",
      "mono": "'IBM Plex Mono', monospace"
    },
    "size": {
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "20px",
      "xl": "28px",
      "2xl": "40px"
    },
    "weight": {
      "regular": "400",
      "medium": "500",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.15",
      "snug": "1.3",
      "normal": "1.5"
    }
  },
  "motion": {
    "fast": "120ms",
    "base": "220ms",
    "slow": "420ms",
    "ease": "cubic-bezier(0.2, 0.7, 0, 1)"
  }
}
